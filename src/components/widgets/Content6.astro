---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import Image from '~/components/common/Image.astro';
const {
  title = await Astro.slots.render('title'),
  sections = [],
  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---
<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-5xl mx-auto ${classes?.container ?? ''}`}
  bg={bg}
>
  <Headline
    title={title}
    classes={{
      container: 'text-center mb-12',
      title: 'text-4xl md:text-5xl font-bold tracking-tighter font-heading',
    }}
  />
  <div class="space-y-10 max-w-3xl mx-auto text-center">
    {sections.map((section, index) => (
      <div key={index} class="md:text-center">
        <h3 class="text-2xl font-semibold dark:text-white mb-2">{section.subtitle}</h3>

        {section.text && (
          <p
            class="text-lg text-muted dark:text-slate-400 mb-2"
            set:html={section.text}
          />
        )}

        {section.bullets && section.bullets.length > 0 && (
          <div class="text-left inline-block mx-auto">
            <ul class="list-disc list-inside text-lg text-muted dark:text-slate-400 space-y-1">
              {section.bullets.map((bullet, i) => (
                <li key={i}>{bullet}</li>
              ))}
            </ul>
          </div>
        )}

        {section.images && section.images.length > 0 && (
  <div class="flex flex-wrap justify-center items-center gap-4 mt-4">
    {section.images.map((image, i) => (
      <figure key={i} class="flex flex-col items-center w-full sm:w-[calc(50%-0.5rem)] md:w-[calc(33.333%-0.667rem)]">
        <Image
          class="w-full"
          widths={[400, 800]}
          sizes="(max-width: 767px) 100vw, 33vw"
          loading="lazy"
          width={400}
          src={image.src}
          alt={image.alt ?? ''}
        />
        {image.caption && (
          <figcaption class="mt-2 text-sm text-muted dark:text-slate-400">
            {image.caption}
          </figcaption>
        )}
      </figure>
    ))}
  </div>
)}
      </div>
    ))}
  </div>
</WidgetWrapper>